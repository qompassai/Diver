set -euo pipefail
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
PREFIX="${PREFIX:-$HOME/.local}"
BUILD_DIR="$XDG_CACHE_HOME/luarocks-build"
mkdir -p "$BUILD_DIR"
cd "$BUILD_DIR"

echo "Detecting latest LuaRocks release..."
latest_tag="$(
  curl -s https://api.github.com/repos/luarocks/luarocks/releases/latest |
    grep -Eo '"tag_name":\s*"[^"]+"' |
    head -n1 |
    cut -d'"' -f4
)"
latest_version="${latest_tag#v}"

cd || /tmp
wget https://luarocks.org/releases/luarocks-3.13.0.tar.gz
tar zxpf luarocks-3.13.0.tar.gz
cd || luarocks-3.13.0
./configure \
  --prefix="$XDG_DATA_HOME/lua/luajit" \
  --with-lua-include=/usr/include/luajit-2.1 \
  --lua-version=5.1 \
  --sysconfdir="$XDG_CONFIG_HOME/luarocks"
make
make install
